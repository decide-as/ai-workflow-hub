#!/usr/bin/env bash
set -euo pipefail

# Block direct commits to master/main.
# All changes must go through a feature branch and be merged via pull request.

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
if [[ "$branch" == "master" || "$branch" == "main" ]]; then
  echo "[!!] Direct commits to $branch are not allowed." >&2
  echo "[!!] Create a feature branch first." >&2
  exit 1
fi

# Run ruff lint and format checks on staged Python files.
# Only runs if ruff is available (skipped gracefully in environments without it).
if command -v ruff &>/dev/null; then
  staged_py="$(git diff --cached --name-only --diff-filter=ACM -- '*.py')"
  if [[ -n "$staged_py" ]]; then
    if ! ruff check $staged_py; then
      echo "[!!] ruff check failed. Fix lint errors before committing." >&2
      exit 1
    fi
    if ! ruff format --check $staged_py; then
      echo "[!!] ruff format check failed. Run 'ruff format' and re-stage." >&2
      exit 1
    fi
  fi
fi
